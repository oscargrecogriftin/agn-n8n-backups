g(0, 7) || 'N/A';\n  \n  return `\n    <tr>\n      <td style=\"padding:7px 12px;border-bottom:1px solid #eee;font-size:13px;\">${nombre}</td>\n      <td style=\"padding:7px 12px;border-bottom:1px solid #eee;text-align:right;color:#888;font-size:13px;\">${tamaño}</td>\n      <td style=\"padding:7px 12px;border-bottom:1px solid #eee;text-align:center;font-size:13px;\">\n        <a href=\"${commitUrl}\" style=\"color:#3498db;text-decoration:none;\">${sha}</a>\n      </td>\n    </tr>`;\n}).join('');\n\nconst fecha = archivos[0]?.json.commit?.message || 'N/A';\nconst total = archivos.length;\n\nconst html = `\n<div style=\"font-family:Arial,sans-serif;max-width:750px;margin:0 auto;color:#333;\">\n  <h1 style=\"background:#2c3e50;color:#fff;padding:16px 20px;margin:0;border-radius:6px 6px 0 0;\">\n    ✅ Backup AGN-N8N → GitHub\n  </h1>\n  <div style=\"background:#f8f9fa;padding:16px 20px;border:1px solid #e0e0e0;\">\n    <p style=\"margin:4px 0;\">📅 <strong>Fecha:</strong> ${fecha}</p>\n    <p style=\"margin:4px 0;\">📦 <strong>Flujos respaldados:</strong> ${total}</p>\n    <p style=\"margin:4px 0;\">🔗 <strong>Repositorio:</strong> \n      <a href=\"https://github.com/oscargrecogriftin/agn-n8n-backups\" style=\"color:#3498db;\">agn-n8n-backups</a>\n    </p>\n  </div>\n  <table style=\"width:100%;border-collapse:collapse;border:1px solid #e0e0e0;\">\n    <thead>\n      <tr style=\"background:#34495e;color:#fff;\">\n        <th style=\"padding:10px 12px;text-align:left;\">Flujo</th>\n        <th style=\"padding:10px 12px;text-align:right;\">Tamaño</th>\n        <th style=\"padding:10px 12px;text-align:center;\">Commit</th>\n      </tr>\n    </thead>\n    <tbody>\n      ${filas}\n    </tbody>\n  </table>\n  <p style=\"color:#aaa;font-size:11px;padding:12px 0;text-align:center;\">\n    Generado automáticamente por n8n\n  </p>\n</div>`;\n\nreturn [{ json: { html_resumen: html, total_flujos: total, fecha } }];\n\n"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3120,3